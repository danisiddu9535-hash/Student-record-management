/// ================= ANIMATION ROUTE =================
Route slideRoute(Widget page) {
  return PageRouteBuilder(
    transitionDuration: const Duration(milliseconds: 300),
    pageBuilder: (_, _, _) => page,
    transitionsBuilder: (_, anim, _, child) {
      return SlideTransition(
        position: Tween(
          begin: const Offset(1, 0),
          end: Offset.zero,
        ).animate(anim),
        child: child,
      );
    },
  );
}

/// ================= MODEL =================
class Student {
  final int id;
  final String registerNumber;
  final String name;
  final String course;
  final DateTime dob;
  final String address;
  final String studentMobile;
  final String fatherName;
  final String fatherMobile;
  final String motherName;
  final String motherMobile;
  final String? guardianName;
  final String? guardianMobile;

  Student({
    required this.id,
    required this.registerNumber,
    required this.name,
    required this.course,
    required this.dob,
    required this.address,
    required this.studentMobile,
    required this.fatherName,
    required this.fatherMobile,
    required this.motherName,
    required this.motherMobile,
    this.guardianName,
    this.guardianMobile,
  });
}

/// ================= AUTH =================
class AuthProvider extends ChangeNotifier {
  final Map<String, String> _users = {
    "admin": "1234",
    "test": "pass",
  }; // preloaded users
  String? _currentUser;

  bool get isRegistered => _users.isNotEmpty;
  String? get username => _currentUser;

  void register(String user, String pass) {
    if (_users.containsKey(user)) return;
    _users[user] = pass;
    notifyListeners();
  }

  bool login(String user, String pass) {
    if (_users.containsKey(user) && _users[user] == pass) {
      _currentUser = user;
      notifyListeners();
      return true;
    }
    return false;
  }

  void logout() {
    _currentUser = null;
    notifyListeners();
  }
}

/// ================= PROVIDER =================
class StudentData extends ChangeNotifier {
  final List<Student> _students = [];

  List<Student> get students => _students;

  void addStudent(Student s) {
    _students.add(s);
    notifyListeners();
  }

  void deleteStudent(int id) {
    _students.removeWhere((s) => s.id == id);
    notifyListeners();
  }

  List<Student> search(String q) {
    if (q.isEmpty) return students;
    return students
        .where((s) =>
    s.name.toLowerCase().contains(q.toLowerCase()) ||
        s.registerNumber.toLowerCase().contains(q.toLowerCase()))
        .toList();
  }
}

